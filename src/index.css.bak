@import "tailwindcss";

:root {
    --bg: #000000;
    --primary: #00f2ff;
    --danger: #ff004c;
    --gold: #ffcc00;
    --parchment: #f2e6d0;
    --ui-bg: rgba(5, 5, 10, 0.95);
    --panel-bg: rgba(5, 5, 12, 0.98);
    --moss: #2d4c1e;
}

* {
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
    user-select: none;
}

body {
    margin: 0;
    padding: 0;
    background-color: var(--bg);
    color: #eee;
    font-family: 'Inter', system-ui, sans-serif;
    height: 100vh;
    width: 100vw;
    display: flex;
    flex-direction: column;
    touch-action: none;
    overscroll-behavior: none;
    /* Prevent rubber-banding on mobile */
    overflow: hidden;
    -webkit-user-select: none;
    user-select: none;
    -webkit-touch-callout: none;
    -webkit-tap-highlight-color: transparent;
}

/* Ensure full screen covers for mobile status bits */
@viewport {
    width: device-width;
    zoom: 1.0;
}

/* Sahne Yönetimi */
.game-container {
    display: flex;
    flex-direction: column;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    position: relative;
    background: var(--bg);
}

.scene {
    position: absolute;
    inset: 100px 0 0 0;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    background: var(--bg);
}

.scene.active {
    display: flex;
}

/* Splash Screen Cinematic Overhaul */
#splash-screen {
    background: #020205 url('https://www.transparenttextures.com/patterns/dark-matter.png');
    overflow: hidden;
    position: fixed;
    inset: 0;
    z-index: 5000;
    /* Above regular HUD for first launch */
    top: 0 !important;
    /* Ignore the header shift for splash */
}

.splash-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent 0%, rgba(0, 0, 0, 0.8) 100%);
    z-index: 5;
}

#splash-content {
    position: relative;
    z-index: 10;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
}

.splash-title-container {
    perspective: 1000px;
}

.splash-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(3rem, 10vw, 5rem);
    font-weight: 900;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 15px;
    margin: 0;
    text-shadow:
        0 0 20px rgba(0, 242, 255, 0.5),
        0 0 40px rgba(0, 242, 255, 0.2),
        2px 2px 10px #000;
    animation: titleFloat 4s ease-in-out infinite;
    position: relative;
}

.splash-title::after {
    content: 'Gölge Labirenti';
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    color: rgba(255, 204, 0, 0.2);
    filter: blur(8px);
    z-index: -1;
}

.splash-subtitle {
    font-size: 0.9rem;
    color: var(--gold);
    letter-spacing: 6px;
    text-transform: uppercase;
    opacity: 0.8;
    margin-top: -10px;
}

/* Premium Start Button */
.btn-start-game {
    position: relative;
    padding: 20px 60px;
    background: rgba(10, 10, 15, 0.8);
    border: 1px solid var(--gold);
    color: var(--gold);
    font-family: 'Cinzel', serif;
    font-size: 1.2rem;
    font-weight: bold;
    letter-spacing: 4px;
    text-transform: uppercase;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.4s;
    box-shadow: 0 0 20px rgba(0, 0, 0, 0.5);
    clip-path: polygon(10% 0, 90% 0, 100% 50%, 90% 100%, 10% 100%, 0 50%);
}

.btn-start-game:hover {
    background: var(--gold);
    color: #000;
    box-shadow: 0 0 40px rgba(255, 204, 0, 0.5);
    transform: scale(1.05);
}

.btn-start-game::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.1), transparent);
    transform: rotate(45deg);
    animation: shine 3s infinite;
}

@keyframes shine {
    0% {
        left: -100%;
    }

    100% {
        left: 100%;
    }
}

@keyframes titleFloat {

    0%,
    100% {
        transform: translateY(0) rotateX(5deg);
    }

    50% {
        transform: translateY(-15px) rotateX(-5deg);
    }
}

/* Runic Background Elements */
.splash-runes {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
}

.floating-rune {
    position: absolute;
    color: rgba(0, 242, 255, 0.1);
    font-size: 2rem;
    filter: blur(1px);
    animation: runePulse 5s infinite alternate ease-in-out;
}

@keyframes runePulse {
    from {
        opacity: 0.2;
        transform: scale(1);
    }

    to {
        opacity: 0.6;
        transform: scale(1.2);
    }
}


.rune-float {
    position: absolute;
    color: rgba(255, 204, 0, 0.05);
    font-size: 3rem;
    animation: floatRune 12s infinite linear;
    pointer-events: none;
    z-index: 3;
}

@keyframes floatRune {
    0% {
        transform: translateY(110vh) rotate(0deg);
        opacity: 0;
    }

    20% {
        opacity: 0.3;
    }

    80% {
        opacity: 0.3;
    }

    100% {
        transform: translateY(-10vh) rotate(360deg);
        opacity: 0;
    }
}

#splash-content {
    z-index: 10;
    text-align: center;
    animation: contentFade 5s forwards;
}

.lantern-pulse {
    width: 80px;
    height: 80px;
    background: var(--primary);
    border-radius: 50%;
    margin: 0 auto 30px;
    filter: blur(20px);
    animation: pulseLight 3s infinite;
}

.splash-title {
    font-family: 'Cinzel', serif;
    font-size: 2.2rem;
    letter-spacing: 12px;
    color: #fff;
    text-transform: uppercase;
    text-shadow: 0 0 15px rgba(255, 255, 255, 0.5);
    margin-bottom: 10px;
}

.splash-subtitle {
    font-size: 0.8rem;
    color: var(--primary);
    letter-spacing: 4px;
    text-transform: uppercase;
    opacity: 0.7;
}

@keyframes pulseLight {

    0%,
    100% {
        transform: scale(1);
        opacity: 0.4;
    }

    50% {
        transform: scale(1.3);
        opacity: 0.8;
    }
}

@keyframes contentFade {
    0% {
        opacity: 0;
        transform: scale(0.95);
    }

    20% {
        opacity: 1;
        transform: scale(1);
    }

    80% {
        opacity: 1;
        transform: scale(1);
    }

    100% {
        opacity: 0;
        transform: scale(1.05);
    }
}

/* --- KAPI SAHNESİ --- */
#door-scene {
    background: #020203;
    z-index: 1500;
    overflow: hidden;
    /* Prevent scroll/overflow from vmax wrapper */
}

.door-subtitle {
    position: absolute;
    top: 50px;
    left: 50%;
    transform: translateX(-50%);
    color: var(--gold);
    letter-spacing: 12px;
    font-size: 0.9rem;
    font-family: 'Cinzel', serif;
    font-weight: 700;
    text-transform: uppercase;
    text-shadow: 0 0 20px rgba(0, 0, 0, 1);
    z-index: 100;
    opacity: 0.8;
}

/* Kapı Geri Butonu */
.btn-gate-back {
    position: absolute;
    top: 30px;
    left: 30px;
    width: 50px;
    height: 50px;
    background: rgba(0, 0, 0, 0.7);
    border: 2px solid var(--gold);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold);
    font-size: 1.5rem;
    cursor: pointer;
    z-index: 2000;
    box-shadow: 0 0 15px rgba(255, 204, 0, 0.3);
    transition: 0.3s;
    pointer-events: auto;
}

.btn-gate-back:active {
    transform: scale(0.9);
    background: var(--gold);
    color: #000;
}

/* Gate Image */
/* Hybrid 3D Gate Scene */
/* Hybrid 3D Gate Scene Refinement */
.gate-image-wrapper {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.65);
    width: 100vmax;
    /* Stretch to cover the whole screen in any orientation */
    height: 100vmax;
    cursor: pointer;
    z-index: 10;
    perspective: 1500px;
    border-radius: 0;
}

.gate-arch-base {
    position: absolute;
    inset: 0;
    background: url('/gate.png') center/cover no-repeat;
    border-radius: 8px;
    box-shadow:
        inset 0 0 100px rgba(0, 0, 0, 0.8),
        0 20px 60px rgba(0, 0, 0, 0.9);
    z-index: 1;
}

/* Refined Hybrid 3D Gate - Slightly wider base, Broad upper arch */
.door-3d-container {
    position: absolute;
    top: 24.2%;
    left: 32.75%;
    width: 34.5%;
    height: 62.3%;
    display: flex;
    transform-style: preserve-3d;
    z-index: 5;
}

/* No separate seam light - unified with door edge glow */

.door-leaf {
    position: relative;
    width: 50%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 3.5s cubic-bezier(0.6, -0.2, 0.5, 1);
}

.door-leaf.left {
    transform-origin: left;
}

.door-leaf.right {
    transform-origin: right;
}

/* Subtle edge glow on inner side - only in the straight door area */
.door-leaf.left::before {
    content: '';
    position: absolute;
    right: -2px;
    top: 40%;
    /* Start below the arch curve */
    bottom: 0;
    width: 5px;
    background: linear-gradient(to left, rgba(255, 100, 0, 0.3), transparent);
    filter: blur(3px);
    z-index: 6;
    animation: lightSpread 4s infinite ease-in-out;
}

.door-leaf.right::before {
    content: '';
    position: absolute;
    left: -2px;
    top: 40%;
    bottom: 0;
    width: 5px;
    background: linear-gradient(to right, rgba(255, 100, 0, 0.3), transparent);
    filter: blur(3px);
    z-index: 6;
    animation: lightSpread 4s infinite ease-in-out;
}

.door-texture {
    position: absolute;
    inset: 0;
    background: url('/gate.png') no-repeat;
    background-size: 579.7% 160.5%;
    backface-visibility: hidden;
    transform-style: preserve-3d;
    box-shadow: inset 0 0 15px rgba(0, 0, 0, 0.5);
}

.door-leaf.left .door-texture {
    background-position: 40.7% 64.2%;
    border-right: 1px solid rgba(255, 80, 0, 0.3);
    border-radius: 100% 0 0 0 / 38% 0 0 0;
}

.door-leaf.right .door-texture {
    background-position: 60.4% 64.2%;
    border-left: 1px solid rgba(255, 80, 0, 0.3);
    border-radius: 0 100% 0 0 / 0 38% 0 0;
}

/* Thickness for 3D doors */
.door-leaf::after {
    content: '';
    position: absolute;
    top: 0;
    width: 15px;
    height: 100%;
    background: #0d0b08;
    transform-style: preserve-3d;
}

.door-leaf.left::after {
    right: -15px;
    transform-origin: left;
    transform: rotateY(90deg);
}

.door-leaf.right::after {
    left: -15px;
    transform-origin: right;
    transform: rotateY(-90deg);
}

/* Opening animation */
.gate-image-wrapper.open .door-leaf.left {
    transform: rotateY(-110deg);
}

.gate-image-wrapper.open .door-leaf.right {
    transform: rotateY(110deg);
}

/* Portal glow behind doors */
.portal-glow {
    position: absolute;
    top: 24.2%;
    left: 32.75%;
    width: 34.5%;
    height: 62.3%;
    background: radial-gradient(circle at center, #fff 0%, var(--gold) 40%, #ff6600 70%, transparent 100%);
    filter: blur(25px);
    opacity: 0;
    transition: opacity 2s 1s;
    z-index: 2;
    animation: portalPulse 3s infinite alternate;
}

@keyframes portalPulse {
    from {
        transform: scale(1);
        filter: blur(20px);
    }

    to {
        transform: scale(1.1);
        filter: blur(30px);
        opacity: 0.9;
    }
}

.gate-image-wrapper.open .portal-glow {
    opacity: 1;
}

/* Scene Impact */
.gate-image-wrapper.open {
    animation: gateShake 0.4s cubic-bezier(.36, .07, .19, .97) both;
}

@keyframes gateShake {

    10%,
    90% {
        transform: translate(-50%, -50%) scale(0.65) translate3d(-2px, 0, 0);
    }

    20%,
    80% {
        transform: translate(-50%, -50%) scale(0.65) translate3d(3px, 0, 0);
    }

    30%,
    50%,
    70% {
        transform: translate(-50%, -50%) scale(0.65) translate3d(-4px, 0, 0);
    }
}

/* Ultra-Softened Ambient Torch - No sharp edges */
.torch-flame {
    position: absolute;
    width: 25px;
    height: 40px;
    z-index: 20;
    border-radius: 50% 50% 40% 40%;
    /* Very soft alpha-based gradient */
    background: radial-gradient(ellipse at bottom,
            rgba(255, 180, 50, 0.5) 0%,
            rgba(255, 100, 0, 0.3) 50%,
            rgba(200, 50, 0, 0.1) 80%,
            transparent 100%);
    filter: blur(5px);
    /* Set to 0.5s to sync with seam */
    animation: torchFlicker 0.5s infinite alternate ease-in-out;
    pointer-events: none;
}

/* Atmospheric Aura - Restored Intensity */
.torch-flame::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 150px;
    height: 150px;
    background: radial-gradient(circle,
            rgba(255, 120, 0, 0.15) 0%,
            rgba(150, 50, 0, 0.05) 60%,
            transparent 100%);
    filter: blur(35px);
    z-index: -1;
    animation: lightSpread 4s infinite ease-in-out;
}

/* Secondary layer for heat haze */
.torch-flame::after {
    content: '';
    position: absolute;
    inset: -10px;
    background: radial-gradient(circle, rgba(255, 150, 0, 0.05) 0%, transparent 80%);
    filter: blur(15px);
}

.left-flame {
    top: 38%;
    left: 16.3%;
}

.right-flame {
    top: 38%;
    right: 16.3%;
}

@keyframes lightSpread {

    0%,
    100% {
        opacity: 0.4;
        transform: translate(-50%, -50%) scale(0.9);
    }

    50% {
        opacity: 0.7;
        transform: translate(-50%, -50%) scale(1.3);
    }
}

@keyframes torchFlicker {
    0% {
        transform: scaleY(1) scaleX(1) skewX(2deg);
        opacity: 0.6;
    }

    100% {
        transform: scaleY(1.15) scaleX(0.9) skewX(-2deg);
        opacity: 0.9;
    }
}

.gate-overlay {
    position: absolute;
    inset: 0;
    border-radius: 8px;
    background: transparent;
    transition: background 2s;
    pointer-events: none;
    z-index: 3;
}

.gate-image-wrapper.open .gate-overlay {
    background: radial-gradient(circle at center 55%, rgba(255, 204, 0, 0.3) 0%, rgba(255, 100, 0, 0.15) 40%, transparent 70%);
}

.door-hint {
    position: absolute;
    bottom: 50px;
    left: 50%;
    transform: translateX(-50%);
    color: var(--gold);
    opacity: 0.6;
    font-size: 0.8rem;
    letter-spacing: 5px;
    font-family: 'Inter', sans-serif;
    animation: pulseHint 3s infinite;
    z-index: 100;
    text-shadow: 0 0 10px rgba(0, 0, 0, 0.8);
}

@keyframes pulseHint {

    0%,
    100% {
        opacity: 0.4;
    }

    50% {
        opacity: 0.8;
        text-shadow: 0 0 10px rgba(255, 204, 0, 0.5);
    }
}

/* Soul Portal Removed */

#transition-whiteout {
    position: fixed;
    inset: 0;
    background: #fff;
    opacity: 0;
    pointer-events: none;
    z-index: 3000;
    transition: opacity 1.5s;
}

#transition-whiteout.active {
    opacity: 1;
}

#map-screen {
    background-color: #e2cfa7;
    background-image:
        radial-gradient(ellipse at center, transparent 30%, rgba(80, 50, 20, 0.2) 100%),
        url('https://www.transparenttextures.com/patterns/aged-paper.png');
    padding: 0;
    overflow: hidden;
}

/* Vignette for full-screen map feel */
#map-screen::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent 40%, rgba(0, 0, 0, 0.4) 110%);
    pointer-events: none;
    z-index: 5;
}

.torchlight-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1000;
    background: radial-gradient(circle 500px at var(--mouse-x, 50vw) var(--mouse-y, 50vh),
            rgba(255, 204, 0, 0.08) 0%,
            transparent 70%);
    mix-blend-mode: soft-light;
    transition: opacity 0.5s;
}

.map-vignette {
    display: none;
    /* Replaced by torchlight-overlay */
}

.map-mist {
    position: fixed;
    inset: -50%;
    background: radial-gradient(circle at center, rgba(45, 76, 30, 0.05) 0%, transparent 70%);
    filter: blur(100px);
    animation: mistRotate 40s infinite linear;
    pointer-events: none;
    z-index: 1;
}

@keyframes mistRotate {
    from {
        transform: rotate(0deg) scale(1);
    }

    50% {
        transform: rotate(180deg) scale(1.2);
    }

    to {
        transform: rotate(360deg) scale(1);
    }
}

.map-mist.mist-2 {
    filter: blur(80px);
    background: radial-gradient(circle at center, rgba(0, 242, 255, 0.03) 0%, transparent 60%);
    animation: mistRotate 30s infinite linear reverse;
}

.map-container {
    position: relative;
    width: 100%;
    height: 100%;
    background: transparent;
    overflow-y: auto;
    overflow-x: hidden;
    display: block;
    padding-top: 40px;
    padding-bottom: 100px;
    scrollbar-width: none;
    z-index: 20;
}

.map-container::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url('https://www.transparenttextures.com/patterns/stardust.png');
    opacity: 0.1;
    pointer-events: none;
    z-index: 1;
}

.map-container::-webkit-scrollbar {
    display: none;
}

.map-scroll-content {
    position: relative;
    width: 100%;
    max-width: 800px;
    height: 1400px;
    margin: 0 auto;
    background: transparent;
    border: none;
    box-shadow: none;
}

.map-scroll-content::before,
.map-scroll-content::after {
    display: none;
}

.map-node {
    position: absolute;
    width: 80px;
    height: 80px;
    background: #111;
    border: 3px solid #333;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    transform: translate(-50%, -50%);
    z-index: 100;
    box-shadow:
        inset 0 0 15px #000,
        0 10px 30px rgba(0, 0, 0, 0.5);
}

.map-node::before {
    content: '';
    position: absolute;
    inset: -8px;
    border: 1px solid rgba(255, 204, 0, 0.1);
    border-radius: 50%;
}

@keyframes nodeRotate {
    from {
        transform: rotate(0deg);
    }

    to {
        transform: rotate(360deg);
    }
}

.map-node.active {
    border-color: var(--gold);
    background: #1a1a1a;
    box-shadow:
        inset 0 0 20px rgba(255, 204, 0, 0.15),
        0 0 50px rgba(255, 204, 0, 0.4);
    transform: translate(-50%, -50%) scale(1.1);
}

.map-node.active:hover {
    transform: translate(-50%, -50%) scale(1.2);
    box-shadow: 0 0 70px rgba(255, 204, 0, 0.6);
    border-color: #fff;
}

.map-node.locked {
    filter: grayscale(1) brightness(0.5);
    cursor: default;
    border-style: dashed;
    border-color: #555;
}

.map-node.active::before {
    border-color: rgba(255, 204, 0, 0.3);
    animation: nodePulse 2s infinite;
}

@keyframes nodePulse {
    0% {
        transform: scale(1);
        opacity: 0.8;
    }

    100% {
        transform: scale(1.4);
        opacity: 0;
    }
}

.map-node i {
    font-size: 0.7rem;
    position: absolute;
    bottom: -25px;
    white-space: nowrap;
    color: #666;
    font-style: normal;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: 0.3s;
}

.node-label {
    position: absolute;
    bottom: -35px;
    white-space: nowrap;
    text-align: center;
    font-family: 'Cinzel', serif;
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #3d2b1f;
    /* Better visibility on map */
    text-shadow: 0 1px 1px rgba(255, 255, 255, 0.3);
    transition: 0.4s;
    pointer-events: none;
}

.map-node.active .node-label {
    color: #000;
    text-shadow: 0 0 20px rgba(255, 204, 0, 0.6);
}

.map-node.active:hover .node-label {
    color: #fff;
    text-shadow: 0 0 25px rgba(255, 255, 255, 1);
}

.node-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
}

.map-path {
    position: absolute;
    height: 4px;
    background: #222;
    transform-origin: left center;
    opacity: 0.6;
    pointer-events: none;
    box-shadow: inset 0 0 5px #000;
    border-radius: 2px;
}

/* --- MYSTIC DARK DASHBOARD HEADER --- */
.mystic-header {
    position: relative;
    width: 100%;
    height: 100px;
    z-index: 2000;
    background: #050508;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 40px;
    border-bottom: 1px solid rgba(255, 204, 0, 0.15);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.9);
    overflow: hidden;
}

.header-glass-layer {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0.02), transparent);
    backdrop-filter: blur(15px);
    pointer-events: none;
}

.header-glow-line {
    position: absolute;
    bottom: 0;
    left: 20%;
    right: 20%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: 0.4;
    filter: blur(1px);
}

.mystic-left,
.mystic-right {
    display: flex;
    align-items: center;
    z-index: 5;
}

/* Soul Plate (Avatar Section) */
.player-soul-plate {
    display: flex;
    align-items: center;
    gap: 15px;
    background: rgba(255, 255, 255, 0.03);
    padding: 8px 18px;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.05);
}

.soul-avatar {
    position: relative;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid var(--gold);
    border-radius: 50%;
}

.avatar-ring {
    position: absolute;
    inset: -3px;
    border: 1px solid rgba(255, 204, 0, 0.2);
    border-radius: 50%;
    border-top-color: var(--gold);
    animation: rotate 4s infinite linear;
}

.soul-lvl {
    position: absolute;
    bottom: -5px;
    right: -5px;
    background: var(--gold);
    color: #000;
    font-size: 0.65rem;
    font-weight: 900;
    padding: 2px 5px;
    border-radius: 4px;
    border: 1px solid #000;
}

.soul-vitals {
    display: flex;
    flex-direction: column;
    gap: 6px;
    width: 120px;
}

.vital-row {
    display: flex;
    align-items: center;
    gap: 8px;
}

.vital-bar {
    flex: 1;
    height: 4px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 2px;
    overflow: hidden;
}

.vital-fill {
    height: 100%;
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

.vital-bar.hp .vital-fill {
    background: #00ffcc;
    box-shadow: 0 0 10px rgba(0, 255, 204, 0.4);
}

.vital-bar.xp .vital-fill {
    background: var(--primary);
    box-shadow: 0 0 10px rgba(0, 242, 255, 0.4);
}

/* Title Group */
.mystic-center {
    z-index: 5;
}

.mystic-title-group {
    text-align: center;
}

.mystic-title-group h1 {
    font-family: 'Cinzel', serif;
    font-size: 1.4rem;
    color: #fff;
    letter-spacing: 8px;
    margin: 0;
    text-shadow: 0 0 25px rgba(255, 204, 0, 0.2);
}

.mystic-subtitle {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
    margin-top: 5px;
}

.line-accent {
    width: 30px;
    height: 1px;
    background: var(--gold);
    opacity: 0.4;
}

.mystic-subtitle span {
    font-size: 0.65rem;
    color: var(--gold);
    letter-spacing: 5px;
    font-weight: 700;
}

/* Stats (Right Side) */
.mystic-stat {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
}

.stat-label {
    font-size: 0.5rem;
    color: var(--gold);
    opacity: 0.6;
    letter-spacing: 2px;
    font-weight: 800;
}

.stat-value-group {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Inter', sans-serif;
    font-size: 1.3rem;
    font-weight: 900;
    color: #fff;
}

.mystic-divider {
    width: 1px;
    height: 30px;
    background: rgba(255, 204, 0, 0.1);
    margin: 0 25px;
}

.mystic-system-status {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.55rem;
    color: #00ffcc;
    letter-spacing: 2px;
    font-weight: 700;
}

.status-indicator {
    width: 6px;
    height: 6px;
    background: #00ffcc;
    border-radius: 50%;
    box-shadow: 0 0 8px #00ffcc;
    animation: pulse 2s infinite;
}

@keyframes rotate {
    from {
        transform: rotate(0deg);
    }

    to {
        transform: rotate(360deg);
    }
}

@media (max-width: 768px) {
    .mystic-header {
        padding: 0 15px;
        height: 85px;
    }

    .soul-vitals,
    .mystic-divider,
    .mystic-system-status {
        display: none;
    }

    .mystic-title-group h1 {
        font-size: 1rem;
        letter-spacing: 4px;
    }

    .line-accent {
        width: 15px;
    }
}

/* Mobile Responsive */
@media (max-width: 768px) {
    .premium-header {
        padding: 0 10px;
        height: 70px;
    }

    .scene {
        inset: 70px 0 0 0;
    }

    .header-center {
        position: relative;
        left: 0;
        top: 0;
        transform: none;
        order: 2;
        flex: 1;
        min-width: 0;
    }

    .header-section.left-panel-header {
        order: 1;
        gap: 8px;
    }

    .header-stat-plate {
        padding: 4px 8px;
        gap: 6px;
    }

    .stat-label {
        font-size: 0.4rem;
    }

    .stat-value {
        font-size: 0.8rem;
    }

    .header-main-title {
        font-size: 0.85rem;
        letter-spacing: 2px;
    }

    .header-subtitle-wrapper span:not(.subtitle-dot) {
        font-size: 0.5rem;
        letter-spacing: 2px;
    }

    .right-panel-header {
        order: 3;
        gap: 8px;
    }

    .status-badge {
        padding: 4px 8px;
    }

    .status-badge span {
        display: none;
        /* Hide 'SİSTEM AKTİF' text on very small screens */
    }

    .title-flank-line {
        display: none;
    }
}

/* Antik Mimari Dekorasyonlar */
.arch-overlay {
    position: absolute;
    inset: 0;
    border: 30px solid transparent;
    border-image: radial-gradient(circle, transparent 70%, rgba(20, 20, 30, 0.8) 100%) 30;
    pointer-events: none;
    z-index: 5;
}

.pillar-decor {
    position: absolute;
    top: 80px;
    bottom: 0;
    width: 40px;
    background: linear-gradient(to right, rgba(0, 0, 0, 0.8), rgba(20, 20, 30, 0.4), transparent);
    border-right: 1px solid rgba(255, 255, 255, 0.05);
    z-index: 5;
}

.pillar-decor.right {
    left: auto;
    right: 0;
    background: linear-gradient(to left, rgba(0, 0, 0, 0.8), rgba(20, 20, 30, 0.4), transparent);
    border-right: none;
    border-left: 1px solid rgba(255, 255, 255, 0.05);
}

.corner-ornament {
    position: absolute;
    width: 100px;
    height: 100px;
    border: 2px solid rgba(255, 204, 0, 0.1);
    z-index: 6;
    pointer-events: none;
}

.corner-tl {
    top: 100px;
    left: 60px;
    border-right: none;
    border-bottom: none;
}

.corner-tr {
    top: 100px;
    right: 60px;
    border-left: none;
    border-bottom: none;
}

.corner-bl {
    bottom: 60px;
    left: 60px;
    border-right: none;
    border-top: none;
}

.corner-br {
    bottom: 60px;
    right: 60px;
    border-left: none;
    border-top: none;
}

/* Bölge Bilgi Paneli */
#region-info-panel {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    width: 90%;
    max-width: 420px;
    background: rgba(15, 15, 20, 0.6) !important;
    backdrop-filter: blur(30px) saturate(200%);
    -webkit-backdrop-filter: blur(30px);
    border: 1px solid rgba(255, 204, 0, 0.3) !important;
    border-radius: 20px !important;
    padding: 30px;
    z-index: 2000;
    transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.4s;
    opacity: 0;
    pointer-events: none;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.8), inset 0 0 20px rgba(255, 204, 0, 0.05) !important;
}

#region-info-panel.active {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
    pointer-events: auto;
}

.region-title {
    font-family: 'Cinzel', serif;
    font-size: 1.4rem;
    color: var(--gold);
    margin-bottom: 10px;
    letter-spacing: 2px;
}

.region-desc {
    font-family: 'Georgia', serif;
    font-style: italic;
    font-size: 0.9rem;
    color: #aaa;
    line-height: 1.4;
    margin-bottom: 20px;
}

.region-stats {
    display: flex;
    justify-content: space-between;
    margin-bottom: 25px;
    padding-top: 15px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.region-stat-item {
    text-align: center;
}

.region-stat-label {
    font-size: 0.6rem;
    color: #555;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.region-stat-value {
    font-size: 0.8rem;
    color: #eee;
    font-weight: bold;
}

.btn-enter-region {
    width: 100%;
    padding: 15px;
    background: var(--gold);
    color: #000;
    border: none;
    border-radius: 8px;
    font-weight: bold;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: 0.3s;
}

.btn-enter-region:active {
    transform: scale(0.98);
    opacity: 0.9;
}

/* Parçacıklar */
/* Parçacıklar Kaldırıldı */
.map-particle {
    display: none;
}

/* HUD Style */
#hud {
    display: none;
    /* Replaced by unified premium-header */
}

.stat {
    display: flex;
    flex-direction: column;
}

.stat-label {
    font-size: 0.65rem;
    color: #555;
    letter-spacing: 2px;
    text-transform: uppercase;
}

.stat-value {
    font-size: 1.2rem;
    font-weight: 900;
    color: var(--primary);
}

/* Oyun İçindeki Geri Butonu */
#game-back-to-map {
    position: absolute;
    top: 20px;
    left: 20px;
    width: 45px;
    height: 45px;
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid var(--gold);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold);
    font-size: 1.2rem;
    cursor: pointer;
    z-index: 200;
    pointer-events: auto;
    transition: 0.3s;
}

/* Bag Icon */
.bag-btn-ui {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 55px;
    height: 55px;
    background: rgba(45, 35, 20, 0.9);
    border: 2px solid var(--gold);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    cursor: pointer;
    z-index: 150;
    pointer-events: auto;
    box-shadow: 0 0 15px rgba(255, 204, 0, 0.4);
}

/* Inventory Panel */
#inventory-panel {
    position: fixed;
    inset: 0;
    background: var(--panel-bg);
    z-index: 4000;
    display: none;
    flex-direction: column;
    padding: 0;
    overflow: hidden;
}

.panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 25px;
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid rgba(255, 204, 0, 0.2);
}

.tab-bar {
    display: flex;
    background: rgba(0, 0, 0, 0.3);
    border-bottom: 1px solid #222;
}

.tab-btn {
    flex: 1;
    padding: 15px;
    text-align: center;
    color: #666;
    font-weight: bold;
    cursor: pointer;
    transition: 0.3s;
    letter-spacing: 1px;
    font-size: 0.9rem;
}

.tab-btn.active {
    color: var(--gold);
    background: rgba(255, 204, 0, 0.05);
    border-bottom: 3px solid var(--gold);
}

.tab-content {
    flex: 1;
    overflow-y: auto;
    padding: 25px;
    display: none;
}

.tab-content.active {
    display: block;
}

/* Shop Styles */
.currency-display {
    background: rgba(255, 204, 0, 0.1);
    border: 1px dashed var(--gold);
    padding: 15px;
    border-radius: 10px;
    text-align: center;
    margin-bottom: 20px;
}

.currency-value {
    font-size: 1.8rem;
    font-weight: 900;
    color: var(--gold);
}

.shop-item {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 20px;
    border-radius: 12px;
    margin-bottom: 15px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.item-info h4 {
    margin: 0 0 5px 0;
    color: var(--primary);
}

.item-info p {
    margin: 0;
    font-size: 0.8rem;
    color: #888;
}

.buy-btn {
    background: var(--gold);
    color: #000;
    border: none;
    padding: 12px 20px;
    border-radius: 8px;
    font-weight: bold;
    font-size: 0.9rem;
    min-width: 90px;
}

.buy-btn:disabled {
    background: #222;
    color: #444;
}

.stat-card {
    background: rgba(255, 255, 255, 0.03);
    border-radius: 12px;
    padding: 12px 15px;
    margin-bottom: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border: 1px solid rgba(0, 242, 255, 0.1);
}

.stat-card i {
    color: var(--primary);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    display: block;
}

.scroll-list-item {
    background: #f4e4bc;
    color: #2d2417;
    padding: 20px;
    border-radius: 2px;
    margin-bottom: 20px;
    border-left: 5px solid #8c6d31;
    font-family: 'Georgia', serif;
    font-size: 1rem;
    font-style: italic;
    box-shadow: 4px 4px 15px rgba(0, 0, 0, 0.6);
    position: relative;
    line-height: 1.6;
    clip-path: polygon(1% 2%, 98% 0%, 100% 98%, 2% 100%, 0% 50%);
}

.scroll-list-item::before {
    content: '◈';
    position: absolute;
    top: 5px;
    right: 10px;
    opacity: 0.2;
    font-size: 1.5rem;
}

/* Health Bar */
#health-container {
    position: absolute;
    top: 20px;
    /* Reduced from 60px since scene starts below header */
    left: 50%;
    transform: translateX(-50%);
    width: 200px;
    height: 10px;
    background: rgba(255, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.2);
    z-index: 110;
    border-radius: 5px;
    overflow: hidden;
}

#health-bar {
    width: 100%;
    height: 100%;
    background: var(--danger);
    transition: width 0.1s;
}

#scroll-count {
    position: absolute;
    top: 45px;
    /* Reduced from 85px since scene starts below header */
    left: 50%;
    transform: translateX(-50%);
    z-index: 110;
    color: var(--gold);
    font-weight: bold;
    font-size: 0.8rem;
    background: rgba(0, 0, 0, 0.4);
    padding: 4px 12px;
    border-radius: 10px;
}

/* Story Popup */
#story-panel {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 85%;
    max-width: 350px;
    background: var(--parchment);
    color: #2d2417;
    padding: 40px 30px;
    z-index: 3500;
    display: none;
    border: 1px solid #a68b5e;
    border-radius: 4px;
    box-shadow:
        0 0 50px rgba(0, 0, 0, 0.9),
        inset 0 0 40px rgba(166, 139, 94, 0.2),
        0 0 0 10px #f2e6d0,
        0 0 0 12px #a68b5e;
    text-align: center;
    background-image: url('https://www.transparenttextures.com/patterns/paper-fibers.png');
}

.story-title {
    font-family: 'Times New Roman', serif;
    font-weight: bold;
    font-size: 0.7rem;
    color: #8c6d31;
    letter-spacing: 2px;
    margin-bottom: 15px;
    border-bottom: 1px solid #d9c5a0;
    padding-bottom: 5px;
}

#story-content {
    font-family: 'Georgia', serif;
    font-style: italic;
    font-size: 1.1rem;
    line-height: 1.5;
}

/* Game Area */
#viewport {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
    background: #000;
}

canvas {
    display: block;
}

#vignette {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 10;
}

#damage-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(circle, transparent 40%, rgba(255, 0, 76, 0.4) 100%);
    z-index: 11;
    opacity: 0;
    transition: opacity 0.2s;
}

/* Controls */
#ui-layer {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 0 25px 40px 25px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    z-index: 50;
    pointer-events: none;
}

.left-controls,
.right-controls {
    pointer-events: auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.btn {
    width: 60px;
    height: 60px;
    background: rgba(20, 20, 30, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.3rem;
    backdrop-filter: blur(5px);
}

#flash-btn {
    width: 50px;
    height: 50px;
    background: var(--gold);
    border-radius: 50%;
    color: #000;
    font-weight: 900;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border: 2px solid #000;
    position: relative;
    overflow: hidden;
    margin-left: auto;
    box-shadow: 0 0 15px rgba(255, 204, 0, 0.4);
}

#cd-timer {
    position: absolute;
    bottom: 0;
    width: 100%;
    height: 0%;
    background: rgba(0, 0, 0, 0.5);
}

/* Modal */
#modal {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.98);
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 5000;
}

.modal-card {
    background: #000;
    padding: 40px;
    border: 1px solid var(--primary);
    text-align: center;
    width: 90%;
    max-width: 380px;
}

.btn-action {
    margin-top: 20px;
    width: 100%;
    padding: 12px;
    background: var(--primary);
    border: none;
    color: #000;
    font-weight: bold;
}

@keyframes shake {
    0% {
        transform: translate(0, 0);
    }

    25% {
        transform: translate(2px, 2px);
    }

    50% {
        transform: translate(-2px, -2px);
    }

    100% {
        transform: translate(0, 0);
    }
}

.shaking {
    animation: shake 0.1s infinite;
}

.hard-shaking {
    animation: shake 0.05s infinite;
}

@keyframes glitch {
    0% {
        transform: translate(0);
        filter: hue-rotate(0deg) contrast(1);
    }

    10% {
        transform: translate(-2px, 1px);
        filter: contrast(1.2);
    }

    20% {
        transform: translate(2px, -1px);
        filter: hue-rotate(90deg);
    }

    40% {
        transform: translate(1.5px, -1.5px);
    }

    50% {
        transform: translate(-3px, 0);
        filter: hue-rotate(180deg);
    }

    100% {
        transform: translate(0);
        filter: hue-rotate(0deg) contrast(1);
    }
}

.glitch-active {
    animation: glitch 0.15s infinite;
}

@keyframes contentFade {
    0% {
        opacity: 0;
        transform: scale(0.95);
    }

    100% {
        opacity: 1;
        transform: scale(1);
    }
}

#splash-content {
    opacity: 1 !important;
}